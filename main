<div id="result"></div>

<script>
function calculateScore() {
    let score = 0;
    for (let i = 1; i <= 10; i++) {
        let answer = document.querySelector('input[name="q' + i + '"]:checked');
        if (!answer) {
            alert("Please answer all questions.");
            return;
        }
        score += parseInt(answer.value);
    }

    let resultDiv = document.getElementById("result");
    resultDiv.className = "result";

    if (score >= 8) {
        resultDiv.classList.add("low");
        resultDiv.innerHTML = "🟢 Low Risk – Great job! You practice strong cyber hygiene.";
    } else if (score >= 5) {
        resultDiv.classList.add("medium");
        resultDiv.innerHTML = "🟡 Moderate Risk – You’re doing okay, but improvements are needed.";
    } else {
        resultDiv.classList.add("high");
        resultDiv.innerHTML = "🔴 High Risk – You may be vulnerable to cyber threats. Consider improving your security habits.";
    }
}
</script>

